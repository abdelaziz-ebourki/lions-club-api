#!/bin/sh
#
# Pre-push hook — runs the full verification suite before allowing a push.
# This includes tests and any lifecycle checks bound to the Maven verify phase.
#

echo "🛡️  Running pre-push verification..."

./mvnw verify -q
RESULT=$?

if [ "$RESULT" -ne 0 ]; then
    echo ""
    echo "❌ Verification failed. Push aborted."
    echo "   Fix the issues before pushing, or use --no-verify to bypass."
    exit 1
fi

echo "✅ All checks pass. Proceeding with push."
exit 0